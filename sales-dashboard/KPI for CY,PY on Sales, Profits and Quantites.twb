          <datasource-dependencies datasource='federated.19wqogn1xwtg7p1bfkbbv0505bjy'>
            <column aggregation='Sum' caption='Current Year' datatype='integer' default-format='n0;-0' name='[Calculation_0170197815173120]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1]' />
